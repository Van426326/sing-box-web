{
  "log": {
    "level": "error",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "localDns",
        "type": "https",
        "server": "223.5.5.5"
      },
      {
        "type": "hosts",
        "path": [],
        "predefined": {},
        "tag": "block"
      }
    ],
    "rules": [],
    "final": "localDns",
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": false,
    "cache_capacity": 4096,
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "address": [
        "172.31.253.1/24"
      ],
      "mtu": 9000,
      "auto_route": true,
      "auto_redirect": true,
      "strict_route": false,
      "endpoint_independent_nat": false,
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "::",
          "server_port": 2080
        }
      }
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 2080,
      "tcp_fast_open": true,
      "tcp_multi_path": true,
      "udp_fragment": true,
      "udp_timeout": "5m",
      "users": [
        {
          "username": "van",
          "password": "<example-password>"
        }
      ]
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "socks",
      "tag": "测试出站",
      "server": "192.168.48.1",
      "server_port": 22222,
      "version": "5",
      "network": "tcp"
    }
  ],
  "route": {
    "default_domain_resolver": "localDns",
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "action": "resolve",
        "strategy": "prefer_ipv4"
      },
      {
        "ip_cidr": [
          "10.10.0.0/24"
        ],
        "outbound": "测试出站"
      }
    ],
    "rule_set": [],
    "final": "direct",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://mirror.ghproxy.com/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "direct",
      "default_mode": "rule"
    }
  }
}
